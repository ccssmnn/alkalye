---
import "#app/index.css"
---

<!doctype html>
<html lang="en" class="bg-background text-foreground">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<title>Alkalye - Write anywhere. Stay in flow.</title>
		<meta
			name="description"
			content="A beautiful markdown editor that works offline, syncs across all your devices, and keeps your words encrypted."
		/>
		<link rel="canonical" href="https://www.alkalye.com/" />
		<link rel="icon" type="image/png" href="/icons/alkalye-icon.png" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Alkalye - Write anywhere. Stay in flow." />
		<meta
			property="og:description"
			content="A beautiful markdown editor that works offline, syncs across all your devices, and keeps your words encrypted."
		/>
		<meta property="og:url" content="https://www.alkalye.com/" />
		<meta
			property="og:image"
			content="https://www.alkalye.com/icons/alkalye-social.png"
		/>
		<script is:inline>
			let languages =
				navigator.languages && navigator.languages.length > 0
					? navigator.languages
					: [navigator.language]
			let locale =
				languages
					.map(language => language.toLowerCase().split("-")[0])
					.find(language => language === "de" || language === "en") ?? "en"
			location.replace(`/${locale}/`)
		</script>
		<script is:inline>
			if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
				document.documentElement.classList.add("dark")
			}
		</script>
	</head>
	<body class="bg-background text-foreground font-sans flex items-center justify-center min-h-screen">
		<div class="flex flex-col items-center gap-6">
			<h1 class="text-2xl font-semibold">Alkalye</h1>
			<div class="flex gap-4">
				<a href="/en/" class="inline-flex min-h-11 items-center justify-center border border-primary bg-primary px-5 text-sm font-medium text-primary-foreground hover:bg-primary/90">English</a>
				<a href="/de/" class="inline-flex min-h-11 items-center justify-center border border-border px-5 text-sm font-medium hover:bg-muted">Deutsch</a>
			</div>
		</div>
	</body>
</html>
